<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ayarlar - Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .tab-nav { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:20px; background:#fff; padding:16px; border-radius:12px; box-shadow:0 1px 4px rgba(0,0,0,.06); }
    .tab-btn { padding:8px 16px; border:1px solid #e2e8f0; border-radius:8px; background:#f8fafc; font-size:12px; font-weight:600; color:#64748b; cursor:pointer; transition:all .2s; font-family:inherit; white-space:nowrap; }
    .tab-btn:hover { background:#f1f5f9; color:#334155; }
    .tab-btn.active { background:#111; color:#fff; border-color:#111; }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
    .settings-card { background:#fff; border-radius:12px; padding:24px; margin-bottom:16px; box-shadow:0 1px 4px rgba(0,0,0,.06); }
    .settings-card h3 { margin:0 0 18px; font-size:15px; font-weight:700; color:#111; padding-bottom:12px; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; gap:8px; }
    .pixel-card { background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:16px; margin-bottom:12px; }
    .pixel-card label { font-weight:600; font-size:13px; color:#374151; margin-bottom:6px; display:block; }
    .pixel-card small { color:#6b7280; font-size:12px; display:block; margin-top:4px; }
    .toggle-row { display:flex; align-items:center; justify-content:space-between; }
    .toggle { position:relative; display:inline-block; width:44px; height:24px; }
    .toggle input { opacity:0; width:0; height:0; }
    .slider-toggle { position:absolute; cursor:pointer; top:0;left:0;right:0;bottom:0; background:#cbd5e1; border-radius:24px; transition:.3s; }
    .slider-toggle:before { position:absolute; content:""; height:18px; width:18px; left:3px; bottom:3px; background:white; border-radius:50%; transition:.3s; }
    .toggle input:checked + .slider-toggle { background:#22c55e; }
    .toggle input:checked + .slider-toggle:before { transform:translateX(20px); }
    .form-row { display:grid; gap:16px; margin-bottom:16px; }
    .form-row.two-col { grid-template-columns:1fr 1fr; }
    .form-row.three-col { grid-template-columns:1fr 1fr 1fr; }
    .save-bar { position:sticky; bottom:0; background:#fff; padding:16px 24px; border-top:1px solid #e2e8f0; z-index:10; border-radius:12px; box-shadow:0 -2px 8px rgba(0,0,0,.06); margin-top:8px; }
    .info-box { border-radius:8px; padding:12px; font-size:12px; line-height:1.6; margin-bottom:12px; }
    .info-box.blue { background:#eff6ff; border:1px solid #bfdbfe; color:#1e40af; }
    .info-box.yellow { background:#fffbeb; border:1px solid #fde68a; color:#92400e; }
    .info-box.green { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; }
    @media(max-width:768px){ .form-row.two-col,.form-row.three-col { grid-template-columns:1fr; } .tab-btn { font-size:11px; padding:6px 12px; } }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <main class="admin-main">
      <div class="admin-header"><h1>Site Ayarlari</h1></div>

      <!-- Tab Navigasyon -->
      <div class="tab-nav">
        <button type="button" class="tab-btn active" onclick="showTab('genel')">Genel</button>
        <button type="button" class="tab-btn" onclick="showTab('iletisim')">Iletisim</button>
        <button type="button" class="tab-btn" onclick="showTab('sosyal')">Sosyal Medya</button>
        <button type="button" class="tab-btn" onclick="showTab('kargo')">Kargo</button>
        <button type="button" class="tab-btn" onclick="showTab('odeme')">Odeme</button>
        <button type="button" class="tab-btn" onclick="showTab('whatsapp')">WhatsApp</button>
        <button type="button" class="tab-btn" onclick="showTab('pixel')">Meta Pixel</button>
        <button type="button" class="tab-btn" onclick="showTab('analytics')">Analytics</button>
        <button type="button" class="tab-btn" onclick="showTab('telegram')">Telegram</button>
        <button type="button" class="tab-btn" onclick="showTab('smtp')">E-posta</button>
        <button type="button" class="tab-btn" onclick="showTab('otomasyon')">Otomasyonlar</button>
      </div>

      <form method="POST" action="/admin/ayarlar" class="admin-form">

        <!-- ========== GENEL ========== -->
        <div class="tab-panel active" id="tab-genel">
          <div class="settings-card">
            <h3>Genel Ayarlar</h3>
            <div class="form-row two-col">
              <div class="form-group"><label>Site Adi</label><input type="text" name="site_name" value="<%= settings.site_name %>"></div>
              <div class="form-group"><label>Site Aciklamasi</label><input type="text" name="site_description" value="<%= settings.site_description %>"></div>
            </div>
            <div class="form-group"><label>Duyuru Bandi</label><input type="text" name="announcement" value="<%= settings.announcement %>" placeholder="Ucretsiz kargo kampanyasi vs..."></div>
          </div>
          <div class="settings-card">
            <h3>Urun Yorumlari</h3>
            <div class="toggle-row">
              <div>
                <label style="font-weight:600;font-size:13px;">Urun Yorumlari</label>
                <small style="color:#6b7280;font-size:12px;">Kapaliysa urun sayfasinda yorum bolumu gorunmez</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="reviews_enabled" value="1" <%= settings.reviews_enabled === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
          </div>
        </div>

        <!-- ========== ILETISIM ========== -->
        <div class="tab-panel" id="tab-iletisim">
          <div class="settings-card">
            <h3>Iletisim Bilgileri</h3>
            <div class="form-row three-col">
              <div class="form-group"><label>Telefon</label><input type="text" name="phone" value="<%= settings.phone %>"></div>
              <div class="form-group"><label>E-posta</label><input type="email" name="email" value="<%= settings.email %>"></div>
              <div class="form-group"><label>Adres</label><input type="text" name="address" value="<%= settings.address %>"></div>
            </div>
          </div>
        </div>

        <!-- ========== SOSYAL MEDYA ========== -->
        <div class="tab-panel" id="tab-sosyal">
          <div class="settings-card">
            <h3>Sosyal Medya Linkleri</h3>
            <div class="form-row three-col">
              <div class="form-group"><label>Instagram URL</label><input type="text" name="instagram" value="<%= settings.instagram %>" placeholder="https://instagram.com/..."></div>
              <div class="form-group"><label>Facebook URL</label><input type="text" name="facebook" value="<%= settings.facebook %>"></div>
              <div class="form-group"><label>Pinterest URL</label><input type="text" name="pinterest" value="<%= settings.pinterest %>"></div>
            </div>
          </div>
        </div>

        <!-- ========== KARGO ========== -->
        <div class="tab-panel" id="tab-kargo">
          <div class="settings-card">
            <h3>Kargo Ayarlari</h3>
            <div class="form-row two-col">
              <div class="form-group"><label>Ucretsiz Kargo Limiti (TL)</label><input type="number" name="free_shipping_limit" value="<%= settings.free_shipping_limit %>"></div>
              <div class="form-group"><label>Kargo Ucreti (TL)</label><input type="number" step="0.01" name="shipping_cost" value="<%= settings.shipping_cost %>"></div>
            </div>
          </div>
        </div>

        <!-- ========== ODEME ========== -->
        <div class="tab-panel" id="tab-odeme">
          <div class="settings-card">
            <h3>Varsayilan Odeme Yontemi</h3>
            <div class="form-group">
              <label>Odeme sayfasinda hangi yontem ustte gorunsun?</label>
              <select name="payment_default_method" style="padding:10px 14px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:14px;width:100%;max-width:400px;">
                <option value="eft" <%= (settings.payment_default_method || "eft") === "eft" ? "selected" : "" %>>Havale / EFT / FAST (varsayilan)</option>
                <option value="cod" <%= settings.payment_default_method === "cod" ? "selected" : "" %>>Kapida Odeme</option>
              </select>
              <small style="color:#6b7280;font-size:11px;margin-top:4px;">Secilen yontem checkout sayfasinda ilk sirada ve secili olarak gosterilir</small>
            </div>
          </div>

          <div class="settings-card">
            <h3>Kapida Odeme</h3>
            <div class="toggle-row" style="margin-bottom:14px;">
              <div>
                <label style="font-weight:600;font-size:13px;">Kapida Nakit Odeme</label>
                <small style="color:#6b7280;font-size:12px;">Musteriler kapida nakit odeme yapabilir</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="cod_cash_enabled" value="1" <%= settings.cod_cash_enabled === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
            <div class="toggle-row" style="margin-bottom:14px;">
              <div>
                <label style="font-weight:600;font-size:13px;">Kapida Kredi Karti ile Odeme</label>
                <small style="color:#6b7280;font-size:12px;">Musteriler kapida kredi karti ile odeme yapabilir</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="cod_card_enabled" value="1" <%= settings.cod_card_enabled === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
            <div class="form-row two-col">
              <div class="form-group">
                <label>Kapida Odeme Ucreti (TL)</label>
                <input type="number" name="cod_fee" value="<%= settings.cod_fee || '0' %>" min="0" step="0.01">
                <small style="color:#6b7280;font-size:11px;">0 girilirse ucret alinmaz, toplam fiyata eklenir</small>
              </div>
              <div class="form-group">
                <label>Kapida Odeme Minimum Sepet Tutari (TL)</label>
                <input type="number" name="cod_min_amount" value="<%= settings.cod_min_amount || '0' %>" min="0" step="1">
                <small style="color:#6b7280;font-size:11px;">0 girilirse limit olmaz. Sepet bu tutarin altindaysa kapida odeme secenegi devre disi olur</small>
              </div>
            </div>
          </div>

          <div class="settings-card">
            <h3>Kredi Karti ile Odeme (Shopier)</h3>
            <div class="toggle-row" style="margin-bottom:14px;">
              <div>
                <label style="font-weight:600;font-size:13px;">Kredi Karti ile Odeme</label>
                <small style="color:#6b7280;font-size:12px;">Musteriler Shopier uzerinden kredi karti / banka karti ile odeme yapabilir. Taksit destegi var.</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="card_payment_enabled" value="1" <%= settings.card_payment_enabled === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
            <div class="form-group">
              <label>Shopier API Token (PAT)</label>
              <input type="text" name="shopier_pat" value="<%= settings.shopier_pat || '' %>" placeholder="eyJ0eXAiOiJKV1Qi...">
              <small style="color:#6b7280;font-size:11px;">Shopier > Ayarlar > Kisisel Erisim Anahtari'ndan alinir</small>
            </div>
          </div>

          <div class="settings-card">
            <h3>Havale / EFT Banka Bilgileri</h3>
            <div class="form-row two-col">
              <div class="form-group"><label>Hesap Sahibi</label><input type="text" name="bank_holder" value="<%= settings.bank_holder || '' %>" placeholder="Ad Soyad veya Sirket Adi"></div>
              <div class="form-group"><label>Banka Adi</label><input type="text" name="bank_name" value="<%= settings.bank_name || '' %>" placeholder="Orn: Ziraat Bankasi"></div>
            </div>
            <div class="form-row two-col">
              <div class="form-group"><label>Sube / Sube Kodu</label><input type="text" name="bank_branch" value="<%= settings.bank_branch || '' %>" placeholder="Orn: Kadikoy Subesi"></div>
              <div class="form-group"><label>IBAN</label><input type="text" name="bank_iban" value="<%= settings.bank_iban || '' %>" placeholder="TR00 0000 0000 0000 0000 0000 00" style="font-family:monospace;letter-spacing:.5px;"></div>
            </div>
          </div>

          <div class="settings-card">
            <h3>Odeme Sayfasi Metinleri</h3>
            <div class="form-group" style="margin-bottom:12px;">
              <label>Havale/EFT Secenek Aciklamasi</label>
              <input type="text" name="payment_eft_desc" value="<%= settings.payment_eft_desc || '' %>" placeholder="Banka havalesi ile guvenli odeme">
              <small style="color:#6b7280;font-size:11px;">Odeme ekraninda Havale/EFT seceneginin altinda gorunur</small>
            </div>
            <div class="form-group">
              <label>Havale Bilgi Notu</label>
              <textarea name="payment_eft_note" rows="3" style="resize:vertical;"><%= settings.payment_eft_note || '' %></textarea>
              <small style="color:#6b7280;font-size:11px;">Siparis tamamlandiktan sonra IBAN bilgileriyle birlikte gosterilir</small>
            </div>
          </div>
        </div>

        <!-- ========== WHATSAPP ========== -->
        <div class="tab-panel" id="tab-whatsapp">
          <div class="settings-card">
            <h3>WhatsApp Siparis Butonu</h3>
            <div class="toggle-row" style="margin-bottom:14px;">
              <div>
                <label style="font-weight:600;font-size:13px;">WhatsApp Siparis Butonu</label>
                <small style="color:#6b7280;font-size:12px;">Urun sayfasinda "Sepete Ekle"nin altinda WhatsApp butonu goster</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="wa_contact_enabled" value="1" <%= settings.wa_contact_enabled === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
            <div class="form-group" style="margin-bottom:10px;">
              <label>WhatsApp Numarasi <small style="color:#9ca3af;">(90 ile baslayan format)</small></label>
              <input type="text" name="wa_contact_number" value="<%= settings.wa_contact_number || '' %>" placeholder="905551234567">
            </div>
            <div class="form-group" style="margin-bottom:10px;">
              <label>Buton Yazisi</label>
              <input type="text" name="wa_contact_btn_text" value="<%= settings.wa_contact_btn_text || 'WhatsApp ile Siparis Ver' %>">
            </div>
            <div class="form-group">
              <label>Mesaj Sablonu <small style="color:#9ca3af;">{urun} yerine urun adi gelir</small></label>
              <input type="text" name="wa_contact_message" value="<%= settings.wa_contact_message || 'Merhaba, {urun} hakkinda bilgi almak istiyorum.' %>">
            </div>
          </div>

          <div class="settings-card" id="whatsapp-settings">
            <h3>WhatsApp Hatirlatma Sistemi</h3>
            <p style="font-size:12px;color:#6b7280;margin:-12px 0 16px;">API gerektirmez. Odeme yapmayan ve sepet terk eden musterileri otomatik tespit eder.</p>

            <div class="pixel-card">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                <input type="checkbox" name="wa_enabled" value="1" <%= settings.wa_enabled === '1' ? 'checked' : '' %>>
                WhatsApp Hatirlatma Sistemini Etkinlestir
              </label>
            </div>

            <div class="pixel-card">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                <input type="checkbox" name="wa_payment_reminder_enabled" value="1" <%= settings.wa_payment_reminder_enabled === '1' ? 'checked' : '' %>>
                Odeme Hatirlatma (Havale/EFT yapmayanlar)
              </label>
              <div style="margin-top:10px;">
                <label style="font-size:12px;color:#6b7280;">Bekleme Suresi (dakika)</label>
                <input type="number" name="wa_payment_reminder_delay" value="<%= settings.wa_payment_reminder_delay || '60' %>" min="5" max="14400" style="width:100px;">
              </div>
              <div style="margin-top:10px;">
                <label style="font-size:12px;color:#6b7280;">Mesaj Sablonu</label>
                <textarea name="wa_payment_reminder_message" rows="3" style="width:100%;font-size:13px;"><%= settings.wa_payment_reminder_message || 'Merhaba {name}, #{order_id} numarali siparisiniz icin odeme bekleniyor. Toplam: {total} TL. IBAN: {iban}' %></textarea>
                <small style="color:#9ca3af;">Degiskenler: {name}, {order_id}, {total}, {iban}, {bank_name}, {bank_holder}, {payment_link}</small>
              </div>
            </div>

            <div class="pixel-card">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                <input type="checkbox" name="wa_abandoned_cart_enabled" value="1" <%= settings.wa_abandoned_cart_enabled === '1' ? 'checked' : '' %>>
                Terk Edilen Sepet Hatirlatma
              </label>
              <div style="margin-top:10px;">
                <label style="font-size:12px;color:#6b7280;">Bekleme Suresi (dakika)</label>
                <input type="number" name="wa_abandoned_cart_delay" value="<%= settings.wa_abandoned_cart_delay || '30' %>" min="5" max="1440" style="width:100px;">
              </div>
              <div style="margin-top:10px;">
                <label style="font-size:12px;color:#6b7280;">Mesaj Sablonu</label>
                <textarea name="wa_abandoned_cart_message" rows="3" style="width:100%;font-size:13px;"><%= settings.wa_abandoned_cart_message || 'Merhaba {name}, sepetinizde {count} urun kaldi. Siparisinizi tamamlayin: {site_url}' %></textarea>
                <small style="color:#9ca3af;">Degiskenler: {name}, {count}, {total}, {site_url}</small>
              </div>
            </div>

            <div class="info-box green">
              <strong>Nasil calisir?</strong> Sistem her 5 dakikada kontrol eder. Odeme yapmayan veya sepet terk eden musteri bulunca Telegram'a bildirim gonderir. Bildirimde "WhatsApp Gonder" butonu vardir.
            </div>
          </div>
        </div>

        <!-- ========== META PIXEL ========== -->
        <div class="tab-panel" id="tab-pixel">
          <div class="settings-card">
            <h3>Meta (Facebook) Pixel</h3>
            <div class="toggle-row" style="margin-bottom:14px;">
              <div>
                <label style="font-weight:600;font-size:13px;">Meta Pixel Aktif</label>
                <small style="color:#6b7280;font-size:12px;">Pixel kodu otomatik olarak tum sayfalara eklenir</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="meta_pixel_active" value="1" <%= settings.meta_pixel_active === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
            <div class="form-group">
              <label>Meta Pixel ID</label>
              <input type="text" name="meta_pixel_id" value="<%= settings.meta_pixel_id || '' %>" placeholder="Orn: 1234567890123456" style="font-family:monospace;">
              <small style="color:#6b7280;font-size:12px;">Facebook Business Manager > Events Manager > Pixel ID</small>
            </div>
            <div class="info-box yellow" style="margin-top:12px;">
              <strong>Otomatik Olaylar:</strong> PageView, ViewContent, AddToCart, InitiateCheckout, Purchase
            </div>
          </div>

          <div class="settings-card">
            <h3>Conversions API (Server-Side)</h3>
            <div class="info-box blue">
              <strong>Neden CAPI?</strong> Tarayici engelleme ve iOS gizlilik kisitlamalarini atlatmak icin server tarafindan dogrudan Meta'ya event gonderir.
            </div>
            <div class="form-group" style="margin-bottom:12px;">
              <label>Conversions API Access Token</label>
              <input type="text" name="meta_capi_token" value="<%= settings.meta_capi_token || '' %>" placeholder="EAAxxxxxxxxx..." style="font-family:monospace;font-size:11px;">
              <small style="color:#6b7280;font-size:11px;">Events Manager > Settings > Generate Access Token</small>
            </div>
            <div class="form-group">
              <label>Test Event Code <span style="font-weight:400;color:#aaa;">(istege bagli)</span></label>
              <input type="text" name="meta_capi_test_code" value="<%= settings.meta_capi_test_code || '' %>" placeholder="TEST12345" style="font-family:monospace;">
              <small style="color:#6b7280;font-size:11px;">Yayina alirken bos birakin.</small>
            </div>
          </div>
        </div>

        <!-- ========== GOOGLE ANALYTICS ========== -->
        <div class="tab-panel" id="tab-analytics">
          <div class="settings-card">
            <h3>Google Analytics</h3>
            <div class="toggle-row" style="margin-bottom:14px;">
              <div>
                <label style="font-weight:600;font-size:13px;">Google Analytics Aktif</label>
                <small style="color:#6b7280;font-size:12px;">GA4 Measurement ID ile takip</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="google_analytics_active" value="1" <%= settings.google_analytics_active === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
            <div class="form-group">
              <label>GA4 Measurement ID</label>
              <input type="text" name="google_analytics_id" value="<%= settings.google_analytics_id || '' %>" placeholder="Orn: G-XXXXXXXXXX" style="font-family:monospace;">
              <small style="color:#6b7280;font-size:12px;">Google Analytics > Admin > Data Streams > Measurement ID</small>
            </div>
          </div>
        </div>

        <!-- ========== TELEGRAM ========== -->
        <div class="tab-panel" id="tab-telegram">
          <div class="settings-card">
            <h3>Telegram Bot</h3>
            <div class="info-box blue">
              <strong>Kurulum:</strong><br>
              1. Telegram'da <strong>@BotFather</strong>'a gidin ve <code>/newbot</code> yazin<br>
              2. Bot adi ve kullanici adi belirleyin<br>
              3. Size verilen <strong>token</strong>'i asagiya yapistirin<br>
              4. Botu baslattiktan sonra bota <code>/start</code> yazin - size Chat ID'nizi verecek
            </div>
            <div class="form-row two-col">
              <div class="form-group">
                <label>Bot Token</label>
                <input type="text" name="telegram_bot_token" value="<%= settings.telegram_bot_token || '' %>" placeholder="123456789:ABCdefGhI..." style="font-family:monospace;font-size:12px;">
              </div>
              <div class="form-group">
                <label>Chat ID</label>
                <input type="text" name="telegram_chat_id" value="<%= settings.telegram_chat_id || '' %>" placeholder="Orn: 123456789" style="font-family:monospace;">
                <small style="color:#6b7280;font-size:11px;">Bota /start yazinca size Chat ID'nizi soyler</small>
              </div>
            </div>
            <div class="info-box green">
              <strong>Bot Ozellikleri:</strong> Yeni siparis bildirimi, inline butonlarla siparis onaylama/iptal/kargoya verme
            </div>
          </div>
        </div>

        <!-- ========== SMTP ========== -->
        <div class="tab-panel" id="tab-smtp">
          <div class="settings-card">
            <h3>E-posta Ayarlari (SMTP)</h3>
            <div class="info-box blue">
              <strong>SMTP Kurulumu:</strong><br>
              Gmail: smtp.gmail.com / 587 / Uygulama Sifresi kullanin<br>
              Yandex: smtp.yandex.com / 465 (SSL) / Mail sifresi
            </div>
            <div class="form-row two-col">
              <div class="form-group"><label>SMTP Sunucu</label><input type="text" name="smtp_host" value="<%= settings.smtp_host || '' %>" placeholder="smtp.gmail.com" style="font-family:monospace;"></div>
              <div class="form-group"><label>Port</label><input type="text" name="smtp_port" value="<%= settings.smtp_port || '587' %>" placeholder="587" style="font-family:monospace;"></div>
            </div>
            <div class="form-row two-col">
              <div class="form-group"><label>Kullanici Adi (E-posta)</label><input type="text" name="smtp_user" value="<%= settings.smtp_user || '' %>" placeholder="mail@domain.com" style="font-family:monospace;"></div>
              <div class="form-group"><label>Sifre / Uygulama Sifresi</label><input type="password" name="smtp_pass" value="<%= settings.smtp_pass || '' %>" placeholder="********"></div>
            </div>
            <div class="form-row two-col">
              <div class="form-group"><label>Gonderen Adi</label><input type="text" name="smtp_from_name" value="<%= settings.smtp_from_name || '' %>" placeholder="FLAVORA"></div>
              <div class="form-group"><label>Gonderen E-posta</label><input type="text" name="smtp_from_email" value="<%= settings.smtp_from_email || '' %>" placeholder="siparis@domain.com"></div>
            </div>
            <div class="toggle-row" style="margin:12px 0;">
              <div>
                <label style="font-weight:600;font-size:13px;">SSL/TLS Baglanti</label>
                <small style="color:#6b7280;font-size:12px;">Port 465 kullaniyorsaniz aktif edin</small>
              </div>
              <label class="toggle">
                <input type="checkbox" name="smtp_secure" value="1" <%= settings.smtp_secure === '1' ? 'checked' : '' %>>
                <span class="slider-toggle"></span>
              </label>
            </div>
            <button type="button" onclick="testSmtp()" style="margin-top:8px;padding:8px 18px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;color:#374151;">
              Test Maili Gonder
            </button>
            <span id="smtpTestResult" style="font-size:12px;margin-left:8px;"></span>
          </div>
        </div>

        <!-- ========== OTOMASYONLAR ========== -->
        <div class="tab-panel" id="tab-otomasyon">
          <div class="settings-card">
            <h3>E-posta Otomasyonlari</h3>

            <div class="pixel-card">
              <div class="toggle-row">
                <div>
                  <label>Siparis Onay E-postasi</label>
                  <small>Yeni siparis olusturuldugunda musteriye otomatik onay maili gider</small>
                </div>
                <label class="toggle">
                  <input type="checkbox" name="order_confirmation_enabled" value="1" <%= settings.order_confirmation_enabled === '1' ? 'checked' : '' %>>
                  <span class="slider-toggle"></span>
                </label>
              </div>
            </div>

            <div class="pixel-card">
              <div class="toggle-row">
                <div>
                  <label>Kargo Bildirim E-postasi</label>
                  <small>Siparis kargoya verildiginde musteriye otomatik bildirim gider</small>
                </div>
                <label class="toggle">
                  <input type="checkbox" name="shipping_notification_enabled" value="1" <%= settings.shipping_notification_enabled === '1' ? 'checked' : '' %>>
                  <span class="slider-toggle"></span>
                </label>
              </div>
            </div>

            <div class="pixel-card" style="border-color:#f59e0b;">
              <div class="toggle-row">
                <div>
                  <label>Terk Edilen Sepet Hatirlatmasi</label>
                  <small>Checkout'a gelip siparis vermeyenlere otomatik hatirlatma maili gider</small>
                </div>
                <label class="toggle">
                  <input type="checkbox" name="abandoned_cart_enabled" value="1" <%= settings.abandoned_cart_enabled === '1' ? 'checked' : '' %>>
                  <span class="slider-toggle"></span>
                </label>
              </div>
            </div>

            <div class="form-row two-col">
              <div class="form-group">
                <label>Bekleme Suresi (dakika)</label>
                <input type="number" name="abandoned_cart_delay" value="<%= settings.abandoned_cart_delay || '30' %>" min="5" max="1440" placeholder="30">
                <small style="color:#6b7280;font-size:11px;">Checkout'tan sonra kac dakika beklenecek</small>
              </div>
              <div class="form-group">
                <label>E-posta Konusu</label>
                <input type="text" name="abandoned_cart_subject" value="<%= settings.abandoned_cart_subject || 'Sepetinizde urunler sizi bekliyor!' %>">
              </div>
            </div>

            <div class="info-box yellow">
              Musteri checkout sayfasina gelip e-posta adresini girdiginde sepet bilgileri kaydedilir. Belirtilen sure icinde siparis tamamlanmazsa, otomatik hatirlatma maili gonderilir.
            </div>
          </div>
        </div>

        <!-- Kaydet Butonu -->
        <div class="save-bar">
          <button type="submit" class="btn btn-primary" style="min-width:200px;">Ayarlari Kaydet</button>
        </div>
      </form>
    </main>
  </div>

  <script>
    function showTab(id) {
      document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
      document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
      document.getElementById('tab-' + id).classList.add('active');
      event.target.classList.add('active');
      localStorage.setItem('settingsTab', id);
    }

    // Sayfa yuklendiginde son acik tab'i hatirla
    (function() {
      var saved = localStorage.getItem('settingsTab');
      if (saved && document.getElementById('tab-' + saved)) {
        document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
        document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
        document.getElementById('tab-' + saved).classList.add('active');
        var btns = document.querySelectorAll('.tab-btn');
        for (var i = 0; i < btns.length; i++) {
          if (btns[i].getAttribute('onclick') && btns[i].getAttribute('onclick').indexOf(saved) > -1) {
            btns[i].classList.add('active');
            break;
          }
        }
      }
    })();

    function testSmtp() {
      var result = document.getElementById('smtpTestResult');
      result.textContent = 'Gonderiliyor...';
      result.style.color = '#6b7280';
      fetch('/admin/api/test-smtp', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          result.textContent = data.success ? 'Test maili gonderildi!' : 'Hata: ' + (data.error || 'Bilinmeyen');
          result.style.color = data.success ? '#16a34a' : '#ef4444';
        })
        .catch(function() {
          result.textContent = 'Baglanti hatasi';
          result.style.color = '#ef4444';
        });
    }
  </script>
</body>
</html>
