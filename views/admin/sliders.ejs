<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Slider - Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <main class="admin-main">
      <div class="admin-header">
        <h1>Slider Yonetimi</h1>
        <button class="btn btn-primary" onclick="document.getElementById('sliderModal').style.display='flex'">+ Yeni Slider</button>
      </div>

      <div class="slider-grid">
        <% sliders.forEach(slide => { %>
        <div class="admin-card slider-card">
          <% if (slide.image) { %><img src="<%= slide.image %>" alt="" style="width:100%;height:200px;object-fit:cover;border-radius:8px;"><% } %>
          <h4><%= slide.title || 'Baslıksız' %></h4>
          <p><%= slide.subtitle || '' %></p>
          <div class="actions" style="margin-top:10px;">
            <form method="POST" action="/admin/slider/sil/<%= slide.id %>" style="display:inline" onsubmit="return confirm('Silmek istediginize emin misiniz?')">
              <button type="submit" class="btn-sm btn-delete">Sil</button>
            </form>
          </div>
        </div>
        <% }); %>
      </div>

      <div class="modal-overlay" id="sliderModal" style="display:none">
        <div class="modal">
          <div class="modal-header">
            <h3>Yeni Slider</h3>
            <button onclick="document.getElementById('sliderModal').style.display='none'">&times;</button>
          </div>
          <form method="POST" action="/admin/slider/kaydet" enctype="multipart/form-data">
            <div class="form-group"><label>Baslik</label><input type="text" name="title"></div>
            <div class="form-group"><label>Alt Baslik</label><input type="text" name="subtitle"></div>
            <div class="form-group"><label>Link</label><input type="text" name="link" placeholder="/urunler"></div>
            <div class="form-group"><label>Gorsel *</label><input type="file" name="image" accept="image/*" required></div>
            <div class="form-row two-col">
              <div class="form-group"><label>Sira</label><input type="number" name="sort_order" value="0"></div>
              <div class="form-group" style="display:flex;align-items:end;"><label class="checkbox-label"><input type="checkbox" name="is_active" value="1" checked> Aktif</label></div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
