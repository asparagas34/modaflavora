<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Siparisler - Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <main class="admin-main">
      <div class="admin-header"><h1>Siparisler (<%= orders.length %>)</h1></div>
      <div class="admin-card">
        <table class="admin-table">
          <thead><tr><th>No</th><th>Musteri</th><th>E-posta</th><th>Toplam</th><th>Odeme</th><th>Durum</th><th>Tarih</th><th></th></tr></thead>
          <tbody>
            <% const statusMap = { pending: 'Beklemede', processing: 'Hazirlaniyor', shipped: 'Kargoda', delivered: 'Teslim Edildi', cancelled: 'Iptal' }; %>
            <% orders.forEach(order => { %>
            <tr>
              <td>#<%= order.id %></td>
              <td><%= order.guest_name || order.user_name || '-' %></td>
              <td><%= order.guest_email || '-' %></td>
              <td><strong><%= order.total.toLocaleString('tr-TR') %> ₺</strong></td>
              <td><%= order.payment_method === 'cod' ? 'Kapida' : 'Havale' %></td>
              <td><span class="status-badge status-<%= order.status %>"><%= statusMap[order.status] || order.status %></span></td>
              <td><%= new Date(order.created_at).toLocaleDateString('tr-TR') %></td>
              <td><a href="/admin/siparisler/<%= order.id %>" class="btn-sm btn-edit">Detay</a></td>
            </tr>
            <% }); %>
            <% if (orders.length === 0) { %>
            <tr><td colspan="8" style="text-align:center;padding:40px;">Henuz siparis yok</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</body>
</html>
