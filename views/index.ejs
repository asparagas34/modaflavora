<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/seo-head') %>
</head>
<body>
  <%- include('partials/header') %>

  <!-- Hero Slider -->
  <section class="hero-slider" id="heroSlider">
    <% if (sliders.length > 0) { %>
      <% sliders.forEach((slide, i) => { %>
      <div class="slide <%= i === 0 ? 'active' : '' %>">
        <img src="<%= slide.image %>" alt="<%= slide.title %>" <%= i > 0 ? 'loading="lazy"' : '' %>>
        <div class="slide-content">
          <% if (slide.title) { %><h2><%= slide.title %></h2><% } %>
          <% if (slide.subtitle) { %><p><%= slide.subtitle %></p><% } %>
          <% if (slide.link) { %><a href="<%= slide.link %>" class="btn btn-white">ALIŞVERİŞE BAŞLA</a><% } %>
        </div>
      </div>
      <% }); %>
      <button class="slider-btn prev" onclick="changeSlide(-1)">&#10094;</button>
      <button class="slider-btn next" onclick="changeSlide(1)">&#10095;</button>
      <div class="slider-dots">
        <% sliders.forEach((s, i) => { %>
        <span class="dot <%= i === 0 ? 'active' : '' %>" onclick="goToSlide(<%= i %>)"></span>
        <% }); %>
      </div>
    <% } else { %>
      <div class="hero-placeholder">
        <h1><%= settings.site_name %></h1>
        <p><%= settings.site_description %></p>
        <a href="/urunler" class="btn btn-primary">ALIŞVERİŞE BAŞLA</a>
      </div>
    <% } %>
  </section>

  <!-- Güven Çizgisi -->
  <div class="trust-strip">
    <div class="container">
      <div class="trust-strip-grid">
        <div class="trust-strip-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <span>Güvenli Ödeme</span>
        </div>
        <div class="trust-strip-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span><%= settings.free_shipping_limit || '2000' %>₺ Üzeri Ücretsiz Kargo</span>
        </div>
        <div class="trust-strip-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>
          <span>14 Gün İade Garantisi</span>
        </div>
        <div class="trust-strip-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span>Müşteri Desteği</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Kategoriler -->
  <% if (categories.length > 0) { %>
  <section class="section categories-section">
    <div class="container">
      <h2 class="section-title">KATEGORİLER</h2>
      <div class="categories-editorial">
        <% categories.forEach((cat, i) => { %>
        <a href="/urunler?kategori=<%= cat.slug %>" class="cat-editorial-card cat-card-<%= i % 5 %>">
          <% if (cat.image) { %>
          <img src="<%= cat.image %>" alt="<%= cat.name %>" loading="lazy">
          <% } else { %>
          <div class="cat-editorial-placeholder"></div>
          <% } %>
          <div class="cat-editorial-overlay">
            <span><%= cat.name %></span>
            <small>İncele</small>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Yeni Gelenler -->
  <% if (newProducts.length > 0) { %>
  <section class="section">
    <div class="container">
      <div class="section-header-line">
        <h2 class="section-title">YENİ GELENLER</h2>
        <a href="/urunler?siralama=yeni" class="section-see-all">Tümünü Gör →</a>
      </div>
      <div class="products-grid">
        <% newProducts.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Editorial Banner 1 - Siyah Blok -->
  <section class="editorial-banner editorial-dark">
    <div class="editorial-banner-inner">
      <div class="editorial-banner-text">
        <small>YENİ KOLEKSİYON</small>
        <h2>Sezonun En<br>Trend Parçaları</h2>
        <p>Şıklığı ve zarafeti bir arada sunan özel tasarımlar.</p>
        <a href="/urunler?siralama=yeni" class="btn btn-white">KEŞFET</a>
      </div>
    </div>
  </section>

  <!-- Öne Çıkanlar -->
  <% if (featuredProducts.length > 0) { %>
  <section class="section">
    <div class="container">
      <div class="section-header-line">
        <h2 class="section-title">ÖNE ÇIKANLAR</h2>
        <a href="/urunler" class="section-see-all">Tümünü Gör →</a>
      </div>
      <div class="products-grid">
        <% featuredProducts.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Editorial Banner 2 - İndirim -->
  <% if (saleProducts.length > 0) { %>
  <section class="editorial-split-banner">
    <div class="editorial-split-text">
      <small>FIRSAT</small>
      <h2>SEÇİLİ ÜRÜNLERDE<br><span>%30 İNDİRİM</span></h2>
      <p>Sezonun en favori parçaları şimdi indirimde.<br>Kaçırmadan sepete ekle.</p>
      <a href="/urunler?indirim=1" class="btn btn-primary">İNDİRİMLERİ KEŞFET</a>
    </div>
    <div class="editorial-split-products">
      <% saleProducts.slice(0, 4).forEach(product => { %>
        <%- include('partials/product-card', { product }) %>
      <% }); %>
    </div>
  </section>
  <% } %>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
