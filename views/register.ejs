<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/seo-head') %>
</head>
<body>
  <%- include('partials/header') %>
  <div class="page-header"><div class="container"><h1>KAYIT OL</h1></div></div>
  <section class="section">
    <div class="container">
      <div class="auth-form">
        <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
        <form method="POST" action="/auth/kayit">
          <div class="form-group"><label>Ad Soyad</label><input type="text" name="name" required></div>
          <div class="form-group"><label>E-posta</label><input type="email" name="email" required></div>
          <div class="form-group"><label>Telefon</label><input type="tel" name="phone"></div>
          <div class="form-group"><label>Şifre</label><input type="password" name="password" required minlength="6"></div>
          <button type="submit" class="btn btn-primary btn-lg btn-block">KAYIT OL</button>
        </form>
        <p class="auth-link">Zaten hesabınız var mı? <a href="/auth/giris">Giriş Yapın</a></p>
      </div>
    </div>
  </section>
  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
