<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/seo-head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="page-header">
    <div class="container">
      <h1><%= currentCategory ? currentCategory.name.toUpperCase() : isIndirim ? 'İNDİRİMLİ ÜRÜNLER' : 'TÜM ÜRÜNLER' %></h1>
      <div class="breadcrumb">
        <a href="/">Anasayfa</a> / <span><%= currentCategory ? currentCategory.name : isIndirim ? 'İndirimli Ürünler' : 'Ürünler' %></span>
      </div>
    </div>
  </div>

  <div class="container products-page">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h3>Filtrele</h3>
        <button class="sidebar-close" id="sidebarClose">&times;</button>
      </div>

      <div class="filter-group">
        <h4>Kategoriler</h4>
        <ul class="filter-list">
          <li><a href="/urunler" class="<%= !query.kategori && !query.indirim ? 'active' : '' %>">Tüm Ürünler</a></li>
          <li><a href="/urunler?indirim=1" class="<%= query.indirim ? 'active' : '' %>" style="color:#e53e3e;font-weight:600;">İndirimli Ürünler</a></li>
          <% categories.filter(c => !c.parent_id).forEach(cat => { %>
          <li>
            <a href="/urunler?kategori=<%= cat.slug %>" class="<%= query.kategori === cat.slug ? 'active' : '' %>"><%= cat.name %></a>
            <% const children = categories.filter(c => c.parent_id === cat.id); %>
            <% if (children.length > 0) { %>
            <ul>
              <% children.forEach(child => { %>
              <li><a href="/urunler?kategori=<%= child.slug %>" class="<%= query.kategori === child.slug ? 'active' : '' %>"><%= child.name %></a></li>
              <% }); %>
            </ul>
            <% } %>
          </li>
          <% }); %>
        </ul>
      </div>
    </aside>

    <main class="products-main">
      <div class="products-toolbar">
        <button class="filter-toggle" id="filterToggle">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/></svg>
          Filtrele
        </button>
        <span class="products-count"><%= total %> ürün</span>
        <select class="sort-select" onchange="window.location.href='/urunler?<%= query.indirim ? 'indirim=1&' : '' %><%= query.kategori ? 'kategori='+query.kategori+'&' : '' %><%= query.ara ? 'ara='+query.ara+'&' : '' %>siralama='+this.value">
          <option value="yeni" <%= query.siralama === 'yeni' ? 'selected' : '' %>>Yeniden Eskiye</option>
          <option value="fiyat-artan" <%= query.siralama === 'fiyat-artan' ? 'selected' : '' %>>Fiyat: Düşükten Yükseğe</option>
          <option value="fiyat-azalan" <%= query.siralama === 'fiyat-azalan' ? 'selected' : '' %>>Fiyat: Yüksekten Düşüğe</option>
          <option value="populer" <%= query.siralama === 'populer' ? 'selected' : '' %>>Popüler</option>
        </select>
      </div>

      <% if (products.length > 0) { %>
      <div class="products-grid" id="productsGrid">
        <% products.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }); %>
      </div>

      <!-- Infinite scroll sentinel -->
      <div id="scrollSentinel" style="height:60px;display:flex;align-items:center;justify-content:center;">
        <% if (hasMore) { %>
        <div id="loadingSpinner" style="display:none;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" style="animation:spin 0.8s linear infinite;">
            <path d="M21 12a9 9 0 11-6.219-8.56"/>
          </svg>
        </div>
        <% } else { %>
        <p style="color:#ccc;font-size:13px;letter-spacing:1px;">— TÜM ÜRÜNLER YÜKLENDİ —</p>
        <% } %>
      </div>

      <% } else { %>
      <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <p>Bu kategoride henüz ürün bulunmamaktadır.</p>
        <a href="/urunler" class="btn btn-outline">Tüm Ürünleri Gör</a>
      </div>
      <% } %>
    </main>
  </div>

  <%- include('partials/footer') %>
<style>
@keyframes spin { to { transform: rotate(360deg); } }
</style>
<script>
<% if (hasMore) { %>
(function() {
  let page = 2;
  let loading = false;
  let done = false;

  const grid = document.getElementById('productsGrid');
  const sentinel = document.getElementById('scrollSentinel');
  const spinner = document.getElementById('loadingSpinner');

  // Mevcut query params
  const qp = new URLSearchParams();
  <% if (query.kategori) { %>qp.set('kategori', '<%= query.kategori %>');<% } %>
  <% if (query.siralama) { %>qp.set('siralama', '<%= query.siralama %>');<% } %>
  <% if (query.ara) { %>qp.set('ara', '<%= query.ara %>');<% } %>
  <% if (query.indirim) { %>qp.set('indirim', '1');<% } %>
  qp.set('_json', '1');

  function renderCard(p) {
    const salePercent = p.sale_price ? Math.round((1 - p.sale_price / p.price) * 100) : 0;
    const priceHtml = p.sale_price
      ? `<span class="price-old">${p.price.toLocaleString('tr-TR')} ₺</span>
         <span class="price-current" style="color:var(--red)">${p.sale_price.toLocaleString('tr-TR')} ₺</span>`
      : `<span class="price-current">${p.price.toLocaleString('tr-TR')} ₺</span>`;

    return `<div class="product-card">
      <div class="product-image">
        <a href="/urun/${p.slug}">
          ${p.image ? `<img src="${p.image}" alt="${p.name}" loading="lazy">` : '<div class="no-image"></div>'}
        </a>
        ${p.sale_price ? `<span class="product-badge sale">%${salePercent}</span>` : ''}
        ${p.is_new ? `<span class="product-badge new">YENİ</span>` : ''}
        <button class="quick-add-btn" onclick="addToCart(${p.id}, '${p.name.replace(/'/g,"\\'")}')">SEPETE EKLE</button>
      </div>
      <div class="product-info">
        <a href="/urun/${p.slug}" class="product-name">${p.name}</a>
        <div class="product-price">${priceHtml}</div>
      </div>
    </div>`;
  }

  async function loadMore() {
    if (loading || done) return;
    loading = true;
    spinner.style.display = 'flex';

    qp.set('sayfa', page);
    try {
      const res = await fetch('/urunler?' + qp.toString());
      const data = await res.json();

      data.products.forEach(p => {
        grid.insertAdjacentHTML('beforeend', renderCard(p));
      });

      page++;
      if (!data.hasMore) {
        done = true;
        sentinel.innerHTML = '<p style="color:#ccc;font-size:13px;letter-spacing:1px;">— TÜM ÜRÜNLER YÜKLENDİ —</p>';
      } else {
        spinner.style.display = 'none';
      }
    } catch(e) {
      spinner.style.display = 'none';
    }
    loading = false;
  }

  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) loadMore();
  }, { rootMargin: '300px' });

  observer.observe(sentinel);
})();
<% } %>
</script>
  <script src="/js/main.js"></script>
</body>
</html>
