<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/seo-head') %>
  <style>
    .ty-wrap { max-width:560px; margin:0 auto; padding:40px 16px 80px; }

    /* Progress Steps */
    .checkout-steps { display:flex; align-items:center; justify-content:center; max-width:480px; margin:0 auto 28px; position:relative; }
    .checkout-step { display:flex; flex-direction:column; align-items:center; gap:6px; flex:1; position:relative; z-index:1; }
    .checkout-step .step-num {
      width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center;
      font-size:13px; font-weight:700; flex-shrink:0; border:2px solid #e5e7eb; color:#9ca3af; background:#fff;
    }
    .checkout-step.done .step-num { border-color:#16a34a; color:#fff; background:#16a34a; }
    .checkout-step .step-label { font-size:12px; font-weight:600; color:#9ca3af; }
    .checkout-step.done .step-label { color:#16a34a; }
    .checkout-steps::before {
      content:''; position:absolute; top:16px; left:16%; right:16%;
      height:2px; background:#16a34a; z-index:0;
    }

    /* Tebrik kartı */
    .ty-card {
      text-align:center; padding:48px 28px 36px;
      background:#fff; border-radius:16px;
      border:1.5px solid #bbf7d0; margin-bottom:20px;
      position:relative; overflow:hidden;
    }
    .ty-card::before {
      content:''; position:absolute; top:0; left:0; right:0; height:4px;
      background:linear-gradient(90deg, #16a34a, #22c55e, #4ade80);
    }
    .ty-icon { font-size:56px; display:block; margin-bottom:16px; animation:popIn .5s ease; }
    @keyframes popIn { 0%{transform:scale(0);opacity:0} 60%{transform:scale(1.2)} 100%{transform:scale(1);opacity:1} }
    .ty-card h2 { font-size:22px; font-weight:800; margin:0 0 8px; color:#111; }
    .ty-card .ty-sub { font-size:14px; color:#6b7280; margin:0 0 20px; line-height:1.5; }
    .ty-badge {
      display:inline-block; background:#f0fdf4; color:#166534;
      border:1px solid #bbf7d0; border-radius:10px;
      padding:8px 20px; font-weight:700; font-size:15px; letter-spacing:.3px;
    }

    /* Sipariş detay */
    .ty-details {
      background:#fff; border:1px solid #e5e7eb;
      border-radius:14px; overflow:hidden; margin-bottom:20px;
    }
    .ty-details-head {
      background:#f9fafb; border-bottom:1px solid #e5e7eb;
      padding:14px 20px; font-size:13px; font-weight:700; color:#111;
      display:flex; align-items:center; gap:8px;
    }
    .ty-item {
      display:flex; justify-content:space-between; align-items:center;
      padding:12px 20px; border-bottom:1px solid #f3f4f6; font-size:13px;
    }
    .ty-item:last-child { border-bottom:none; }
    .ty-item .name { color:#111; font-weight:500; flex:1; }
    .ty-item .qty { color:#9ca3af; margin:0 12px; }
    .ty-item .price { font-weight:700; color:#111; white-space:nowrap; }
    .ty-total {
      display:flex; justify-content:space-between; align-items:center;
      padding:14px 20px; background:#f9fafb; border-top:1px solid #e5e7eb;
      font-size:15px; font-weight:800; color:#111;
    }

    /* Bilgi kartları */
    .ty-info {
      display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px;
    }
    @media(max-width:480px) { .ty-info { grid-template-columns:1fr; } }
    .ty-info-card {
      background:#fff; border:1px solid #e5e7eb; border-radius:10px;
      padding:16px; text-align:center;
    }
    .ty-info-card .ic { font-size:24px; margin-bottom:6px; }
    .ty-info-card strong { display:block; font-size:12px; font-weight:700; color:#111; margin-bottom:2px; }
    .ty-info-card span { font-size:12px; color:#6b7280; }

    /* Butonlar */
    .ty-actions { display:flex; gap:10px; flex-wrap:wrap; }
    .ty-actions .btn { flex:1; min-width:140px; text-align:center; }
  </style>

  <% if (settings.meta_pixel_id) { %>
  <!-- Meta Pixel - Purchase Event -->
  <script>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
    n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
    document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '<%= settings.meta_pixel_id %>');
    fbq('track', 'Purchase', {
      value: <%= order.total %>,
      currency: 'TRY',
      content_type: 'product',
      order_id: '<%= order.id %>',
      contents: <%- JSON.stringify(items.map(i => ({ id: String(i.product_id), quantity: i.quantity, item_price: i.price }))) %>,
      num_items: <%= items.reduce((s, i) => s + i.quantity, 0) %>
    }, { eventID: '<%= purchaseEventId %>' });
  </script>
  <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= settings.meta_pixel_id %>&ev=Purchase&noscript=1"/></noscript>
  <% } %>
</head>
<body>
  <%- include('partials/header') %>

  <section class="section">
    <div class="ty-wrap">

      <!-- Adım Göstergesi - Hepsi tamamlandı -->
      <div class="checkout-steps">
        <div class="checkout-step done">
          <span class="step-num">✓</span>
          <span class="step-label">Sepet</span>
        </div>
        <div class="checkout-step done">
          <span class="step-num">✓</span>
          <span class="step-label">Bilgiler & Ödeme</span>
        </div>
        <div class="checkout-step done">
          <span class="step-num">✓</span>
          <span class="step-label">Tamamlandı</span>
        </div>
      </div>

      <!-- Tebrik Kartı -->
      <div class="ty-card">
        <span class="ty-icon">🎉</span>
        <h2>Tebrikler, Siparişiniz Onaylandı!</h2>
        <p class="ty-sub">Ödemeniz başarıyla alındı. Siparişiniz en kısa sürede hazırlanarak kargoya verilecektir.</p>
        <span class="ty-badge">#<%= order.id %> &nbsp;·&nbsp; <%= order.total.toLocaleString('tr-TR') %> ₺</span>
      </div>

      <!-- Sipariş Detayı -->
      <div class="ty-details">
        <div class="ty-details-head">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          Sipariş Detayı
        </div>
        <% items.forEach(item => { %>
        <div class="ty-item">
          <span class="name"><%= item.product_name %></span>
          <span class="qty">x<%= item.quantity %></span>
          <span class="price"><%= (item.price * item.quantity).toLocaleString('tr-TR') %> ₺</span>
        </div>
        <% }); %>
        <div class="ty-total">
          <span>Toplam</span>
          <span><%= order.total.toLocaleString('tr-TR') %> ₺</span>
        </div>
      </div>

      <!-- Bilgi Kartları -->
      <%
        const now = new Date();
        const d1 = new Date(now); d1.setDate(d1.getDate() + 1);
        if (d1.getDay() === 0) d1.setDate(d1.getDate() + 1);
        if (d1.getDay() === 6) d1.setDate(d1.getDate() + 2);
        const d2 = new Date(d1); d2.setDate(d2.getDate() + 1);
        if (d2.getDay() === 0) d2.setDate(d2.getDate() + 1);
        if (d2.getDay() === 6) d2.setDate(d2.getDate() + 2);
        const months = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
        const fmt = (d) => d.getDate() + ' ' + months[d.getMonth()];
      %>
      <div class="ty-info">
        <div class="ty-info-card">
          <div class="ic"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
          <strong>Tahmini Teslimat</strong>
          <span><%= fmt(d1) %> – <%= fmt(d2) %></span>
        </div>
        <div class="ty-info-card">
          <div class="ic"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
          <strong>Kargo Takibi</strong>
          <span>Kargoya verilince bilgilendirileceksiniz</span>
        </div>
      </div>

      <!-- Butonlar -->
      <div class="ty-actions">
        <% if (user) { %>
        <a href="/siparislerim" class="btn btn-primary">SİPARİŞLERİM</a>
        <% } %>
        <a href="/urunler" class="btn btn-outline">ALIŞVERİŞE DEVAM ET</a>
      </div>

    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
