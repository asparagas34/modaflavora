<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title><%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (settings.site_name + ' - ' + settings.site_description) %></title>
<meta name="description" content="<%= typeof seoDescription !== 'undefined' && seoDescription ? seoDescription : settings.site_description %>">
<% var _hasCanonical = typeof seoCanonical !== 'undefined' && seoCanonical; %>
<meta name="robots" content="<%= (typeof seoNoIndex !== 'undefined' && seoNoIndex) || !_hasCanonical ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1' %>">
<% if (_hasCanonical) { %>
<link rel="canonical" href="<%= seoCanonical %>">
<% } %>

<% if (_hasCanonical) { %>
<!-- Open Graph -->
<meta property="og:type" content="<%= typeof seoType !== 'undefined' && seoType ? seoType : 'website' %>">
<meta property="og:title" content="<%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (settings.site_name + ' - ' + settings.site_description) %>">
<meta property="og:description" content="<%= typeof seoDescription !== 'undefined' && seoDescription ? seoDescription : settings.site_description %>">
<meta property="og:url" content="<%= typeof seoCanonical !== 'undefined' && seoCanonical ? seoCanonical : '' %>">
<meta property="og:site_name" content="<%= settings.site_name %>">
<meta property="og:locale" content="tr_TR">
<% if (typeof seoImage !== 'undefined' && seoImage) { %>
<meta property="og:image" content="<%= seoImage %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<% } %>
<% if (typeof seoPrice !== 'undefined' && seoPrice) { %>
<meta property="product:price:amount" content="<%= seoPrice %>">
<meta property="product:price:currency" content="TRY">
<% } %>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : (settings.site_name + ' - ' + settings.site_description) %>">
<meta name="twitter:description" content="<%= typeof seoDescription !== 'undefined' && seoDescription ? seoDescription : settings.site_description %>">
<% if (typeof seoImage !== 'undefined' && seoImage) { %>
<meta name="twitter:image" content="<%= seoImage %>">
<% } %>
<% } %>

<% if (settings.google_analytics_active === '1' && settings.google_analytics_id) { %>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.google_analytics_id %>"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '<%= settings.google_analytics_id %>');
</script>
<% } %>

<% if (settings.meta_pixel_active === '1' && settings.meta_pixel_id) { %>
<!-- Meta Pixel -->
<script>
!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
document,'script','https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '<%= settings.meta_pixel_id %>');
fbq('track', 'PageView');
</script>
<noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= settings.meta_pixel_id %>&ev=PageView&noscript=1"/></noscript>
<% } %>

<!-- Performance -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="dns-prefetch" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
