<div class="product-card">
  <div class="product-image">
    <a href="/urun/<%= product.slug %>">
      <% if (product.image) { %>
      <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
      <% } else { %>
      <div class="no-image">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
          <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
      <% } %>
    </a>
    <% if (product.sale_price && product.sale_price < product.price) { %>
    <span class="product-badge sale">%<%= Math.round((1 - product.sale_price / product.price) * 100) %></span>
    <% } %>
    <% if (product.is_new) { %>
    <span class="product-badge new">YENİ</span>
    <% } %>
    <button class="quick-add-btn" onclick="addToCart(<%= product.id %>, '<%= product.name.replace(/'/g, "\\'") %>')" title="Sepete Ekle">
      SEPETE EKLE
    </button>
  </div>
  <div class="product-info">
    <a href="/urun/<%= product.slug %>" class="product-name"><%= product.name %></a>
    <div class="product-price">
      <% if (product.sale_price && product.sale_price < product.price) { %>
      <span class="price-old"><%= product.price.toLocaleString('tr-TR') %> ₺</span>
      <span class="price-current"><%= product.sale_price.toLocaleString('tr-TR') %> ₺</span>
      <% } else { %>
      <span class="price-current"><%= product.price.toLocaleString('tr-TR') %> ₺</span>
      <% } %>
    </div>
  </div>
</div>
