<!-- Cart notification -->
<div class="cart-toast" id="cartToast">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
  <span>Ürün sepete eklendi!</span>
</div>

<!-- ===== SEPET ÇEKMECESİ ===== -->
<div class="cart-drawer-overlay" id="cartDrawerOverlay"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-drawer-header">
    <h3>🛒 Sepetim <span class="cart-drawer-count" id="drawerCount">0</span></h3>
    <button class="cart-drawer-close" id="cartDrawerClose" aria-label="Kapat">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="cart-drawer-items" id="cartDrawerItems">
    <div class="cart-drawer-empty" id="cartDrawerEmpty">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <p>Sepetiniz boş</p>
      <a href="/urunler" class="btn-go-shop">Alışverişe Başla</a>
    </div>
  </div>

  <div class="cart-drawer-footer" id="cartDrawerFooter" style="display:none;">
    <div class="cart-drawer-shipping-bar" id="shippingBar"></div>
    <div class="cart-drawer-total">
      <span>Ara Toplam</span>
      <strong id="drawerTotal">0 ₺</strong>
    </div>
    <div class="cart-drawer-total" style="font-size:12px;color:#6b7280;border-top:none;padding-top:0;">
      <span>Kargo</span>
      <span id="drawerShipping">Hesaplanıyor</span>
    </div>
    <a href="/sepet" class="cart-drawer-btn-cart">Sepeti Görüntüle</a>
    <a href="/odeme" class="cart-drawer-btn-checkout">Ödemeye Geç →</a>
    <button onclick="document.getElementById('cartDrawer').classList.remove('open');document.getElementById('cartDrawerOverlay').classList.remove('open');document.body.style.overflow='';" style="width:100%;padding:10px;background:none;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;color:#6b7280;cursor:pointer;margin-top:6px;font-family:inherit;">Alışverişe Devam Et</button>
  </div>
</div>

<!-- Meta Pixel & Google Analytics -->
<% if (settings.meta_pixel_active === '1' && settings.meta_pixel_id) { %>
<!-- Meta Pixel Code -->
<script>
!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window,document,'script',
'https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '<%= settings.meta_pixel_id %>');
fbq('track', 'PageView');
</script>
<noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= settings.meta_pixel_id %>&ev=PageView&noscript=1"/></noscript>
<!-- End Meta Pixel Code -->
<% } %>

<% if (settings.google_analytics_active === '1' && settings.google_analytics_id) { %>
<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.google_analytics_id %>"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '<%= settings.google_analytics_id %>');
</script>
<% } %>

<!-- Organization Schema (tüm sayfalar) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "<%= settings.site_name %>",
  "description": "<%= settings.site_description %>",
  "url": "<%= typeof seoCanonical !== 'undefined' && seoCanonical ? seoCanonical.split('/').slice(0,3).join('/') : '' %>",
  "telephone": "<%= settings.phone %>",
  "email": "<%= settings.email %>",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "<%= settings.address %>"
  }
  <% if (settings.instagram && settings.instagram !== '#') { %>
  ,"sameAs": ["<%= settings.instagram %>"<% if (settings.facebook && settings.facebook !== '#') { %>, "<%= settings.facebook %>"<% } %><% if (settings.pinterest && settings.pinterest !== '#') { %>, "<%= settings.pinterest %>"<% } %>]
  <% } %>
}
</script>
