<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/seo-head') %>
</head>
<body>
  <%- include('partials/header') %>

  <div class="page-header">
    <div class="container">
      <h1>SEPETİM</h1>
      <div class="breadcrumb"><a href="/">Anasayfa</a> / <span>Sepet</span></div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <% if (cart.length > 0) { %>
      <div class="cart-layout">
        <div class="cart-items">
          <table class="cart-table">
            <thead>
              <tr>
                <th>Ürün</th>
                <th>Fiyat</th>
                <th>Adet</th>
                <th>Toplam</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="cartBody">
              <% cart.forEach((item, index) => { %>
              <tr data-index="<%= index %>">
                <td class="cart-product">
                  <div class="cart-product-inner">
                    <% if (item.image) { %>
                    <img src="<%= item.image %>" alt="<%= item.name %>">
                    <% } %>
                    <div>
                      <a href="/urun/<%= item.slug %>"><strong><%= item.name %></strong></a>
                      <% if (item.size) { %><small>Beden: <%= item.size %></small><% } %>
                      <% if (item.color) { %><small>Renk: <%= item.color %></small><% } %>
                    </div>
                  </div>
                </td>
                <td><%= item.price.toLocaleString('tr-TR') %> ₺</td>
                <td>
                  <div class="quantity-selector small">
                    <button onclick="updateCart(<%= index %>, <%= item.quantity - 1 %>)">-</button>
                    <span><%= item.quantity %></span>
                    <button onclick="updateCart(<%= index %>, <%= item.quantity + 1 %>)">+</button>
                  </div>
                </td>
                <td class="item-total"><%= (item.price * item.quantity).toLocaleString('tr-TR') %> ₺</td>
                <td>
                  <button class="remove-btn" onclick="removeFromCart(<%= index %>)" title="Kaldır">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="cart-summary">
          <h3>Sipariş Özeti</h3>
          <% const subtotal = cart.reduce((s, i) => s + i.price * i.quantity, 0); %>
          <% const freeLimit = parseFloat(settings.free_shipping_limit) || 2000; %>
          <% const shipping = subtotal >= freeLimit ? 0 : parseFloat(settings.shipping_cost) || 49.90; %>
          <div class="summary-row"><span>Ara Toplam</span><span id="subtotal"><%= subtotal.toLocaleString('tr-TR') %> ₺</span></div>
          <div class="summary-row"><span>Kargo</span><span id="shipping"><%= shipping === 0 ? 'Ücretsiz' : shipping.toLocaleString('tr-TR') + ' ₺' %></span></div>
          <% if (subtotal < freeLimit) { %>
          <div class="free-shipping-info">
            <strong><%= (freeLimit - subtotal).toLocaleString('tr-TR') %> ₺</strong> daha ekleyin, kargo ücretsiz!
            <div class="progress-bar"><div style="width: <%= Math.min(100, (subtotal / freeLimit) * 100) %>%"></div></div>
          </div>
          <% } %>
          <div class="summary-row total"><span>Toplam</span><span id="total"><%= (subtotal + shipping).toLocaleString('tr-TR') %> ₺</span></div>
          <a href="/siparis" class="btn btn-primary btn-lg btn-block">SİPARİŞİ TAMAMLA</a>
          <a href="/urunler" class="btn btn-outline btn-block">Alışverişe Devam Et</a>
        </div>
      </div>
      <% } else { %>
      <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <h3>Sepetiniz boş</h3>
        <p>Sepetinizde henüz ürün bulunmamaktadır.</p>
        <a href="/urunler" class="btn btn-primary">ALIŞVERİŞE BAŞLA</a>
      </div>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
  <script>
    function updateCart(index, quantity) {
      fetch('/api/cart/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ index, quantity })
      }).then(() => window.location.reload());
    }

    function removeFromCart(index) {
      fetch('/api/cart/remove', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ index })
      }).then(() => window.location.reload());
    }
  </script>
</body>
</html>
