<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/seo-head') %>
</head>
<body>
  <%- include('partials/header') %>
  <div class="page-header"><div class="container"><h1>FAVORİLERİM</h1></div></div>
  <section class="section">
    <div class="container">
      <% if (products.length > 0) { %>
      <div class="products-grid">
        <% products.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }); %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <h3>Henüz favori ürün eklemediniz</h3>
        <a href="/urunler" class="btn btn-primary">ÜRÜNLERİ KEŞFET</a>
      </div>
      <% } %>
    </div>
  </section>
  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
