<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/seo-head') %>
  <style>
    .pr-wrap { max-width: 560px; margin: 0 auto; padding: 30px 16px 80px; }

    .pr-header { text-align: center; margin-bottom: 30px; }
    .pr-header h1 { font-size: 22px; font-weight: 700; color: #111; margin: 0 0 8px; }
    .pr-header p { font-size: 14px; color: #6b7280; margin: 0; }

    .pr-status { text-align: center; padding: 16px; border-radius: 12px; margin-bottom: 24px; }
    .pr-status.pending { background: #fef3c7; border: 1px solid #fde68a; }
    .pr-status.paid { background: #d1fae5; border: 1px solid #a7f3d0; }
    .pr-status .status-text { font-size: 15px; font-weight: 700; }
    .pr-status.pending .status-text { color: #92400e; }
    .pr-status.paid .status-text { color: #065f46; }

    .pr-card { background: #fff; border-radius: 12px; padding: 20px; margin-bottom: 16px; box-shadow: 0 1px 4px rgba(0,0,0,.06); border: 1px solid #f3f4f6; }
    .pr-card h3 { font-size: 14px; font-weight: 700; color: #111; margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid #f3f4f6; }

    .pr-item { display: flex; gap: 12px; padding: 10px 0; border-bottom: 1px solid #f9fafb; }
    .pr-item:last-child { border-bottom: none; }
    .pr-item img { width: 56px; height: 70px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }
    .pr-item-info { flex: 1; min-width: 0; }
    .pr-item-name { font-size: 13px; font-weight: 600; color: #111; margin-bottom: 4px; }
    .pr-item-detail { font-size: 12px; color: #6b7280; }
    .pr-item-price { font-size: 14px; font-weight: 700; color: #111; white-space: nowrap; }

    .pr-totals { margin-top: 14px; padding-top: 14px; border-top: 2px solid #f3f4f6; }
    .pr-total-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 13px; color: #374151; }
    .pr-total-row.grand { font-size: 18px; font-weight: 700; color: #111; padding-top: 10px; margin-top: 6px; border-top: 1px solid #e5e7eb; }

    .pr-iban { background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 10px; padding: 16px; }
    .pr-iban-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; font-size: 13px; }
    .pr-iban-row .label { color: #6b7280; }
    .pr-iban-row .value { font-weight: 600; color: #111; }
    .pr-iban-number { font-family: monospace; font-size: 15px; font-weight: 700; color: #0369a1; letter-spacing: 1px; word-break: break-all; }
    .pr-copy-btn { display: inline-flex; align-items: center; gap: 4px; background: #0ea5e9; color: #fff; border: none; padding: 6px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; margin-top: 8px; }
    .pr-copy-btn:hover { background: #0284c7; }

    .pr-address { font-size: 13px; color: #374151; line-height: 1.6; }

    .pr-note { background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 14px; font-size: 13px; color: #92400e; line-height: 1.5; }

    .pr-btn { display: block; width: 100%; padding: 16px; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; text-align: center; transition: all .15s; }
    .pr-btn.primary { background: #16a34a; color: #fff; }
    .pr-btn.primary:hover { background: #15803d; }
    .pr-btn.primary:disabled { background: #9ca3af; cursor: not-allowed; }
    .pr-btn.success { background: #d1fae5; color: #065f46; cursor: default; }

    .pr-info-row { display: flex; gap: 8px; font-size: 13px; padding: 4px 0; }
    .pr-info-row .label { color: #6b7280; min-width: 100px; }
    .pr-info-row .value { color: #111; font-weight: 500; }

    @media (max-width: 480px) {
      .pr-wrap { padding: 20px 12px 60px; }
      .pr-iban-number { font-size: 13px; }
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <div class="pr-wrap">
    <div class="pr-header">
      <h1>Siparis #<%= order.id %></h1>
      <p>Odeme bilgileri ve siparis ozeti</p>
    </div>

    <% if (order.status === 'pending_payment') { %>
    <div class="pr-status pending">
      <div class="status-text">Odeme Bekleniyor</div>
    </div>
    <% } else if (order.status === 'processing' || order.status === 'shipped' || order.status === 'delivered') { %>
    <div class="pr-status paid">
      <div class="status-text">Odeme Onaylandi</div>
    </div>
    <% } %>

    <% if (order.status === 'pending_payment') { %>
    <!-- IBAN Bilgileri -->
    <div class="pr-card">
      <h3>Banka / Havale Bilgileri</h3>
      <div class="pr-iban">
        <% if (settings.bank_name) { %>
        <div class="pr-iban-row">
          <span class="label">Banka</span>
          <span class="value"><%= settings.bank_name %></span>
        </div>
        <% } %>
        <% if (settings.bank_holder) { %>
        <div class="pr-iban-row">
          <span class="label">Hesap Sahibi</span>
          <span class="value"><%= settings.bank_holder %></span>
        </div>
        <% } %>
        <% if (settings.bank_branch) { %>
        <div class="pr-iban-row">
          <span class="label">Sube</span>
          <span class="value"><%= settings.bank_branch %></span>
        </div>
        <% } %>
        <div style="margin-top:10px;">
          <div style="font-size:11px;color:#6b7280;margin-bottom:4px;">IBAN</div>
          <div class="pr-iban-number" id="ibanText"><%= settings.bank_iban %></div>
          <button class="pr-copy-btn" onclick="copyIban()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            IBAN Kopyala
          </button>
        </div>
        <div style="margin-top:12px;padding-top:10px;border-top:1px solid #bae6fd;">
          <div class="pr-iban-row">
            <span class="label">Odeme Tutari</span>
            <span class="value" style="font-size:18px;color:#0369a1;"><%= order.total?.toLocaleString('tr-TR') %> TL</span>
          </div>
          <div style="font-size:11px;color:#6b7280;margin-top:4px;">
            Aciklama: <strong><%= order.guest_name %> - Siparis #<%= order.id %></strong>
          </div>
        </div>
      </div>
    </div>

    <div class="pr-note">
      Havale/EFT aciklamasina <strong>adinizi ve siparis numaranizi (#<%= order.id %>)</strong> yazmayi unutmayin. Odemeniz onaylandiktan sonra siparisini hazirlanip kargoya verilecektir.
    </div>

    <div style="margin: 16px 0;">
      <button class="pr-btn primary" id="paymentBtn" onclick="confirmPayment()">
        Odemeyi Yaptim
      </button>
    </div>
    <% } %>

    <!-- Siparis Ozeti -->
    <div class="pr-card">
      <h3>Siparis Ozeti</h3>
      <% items.forEach(item => { %>
      <div class="pr-item">
        <% if (item.product_image) { %>
        <img src="/uploads/<%= item.product_image %>" alt="<%= item.product_name %>" loading="lazy">
        <% } %>
        <div class="pr-item-info">
          <div class="pr-item-name"><%= item.product_name %></div>
          <div class="pr-item-detail">
            <% if (item.size) { %>Beden: <%= item.size %><% } %>
            <% if (item.color) { %> | Renk: <%= item.color %><% } %>
            | Adet: <%= item.quantity %>
          </div>
        </div>
        <div class="pr-item-price"><%= (item.price * item.quantity).toLocaleString('tr-TR') %> TL</div>
      </div>
      <% }); %>

      <div class="pr-totals">
        <div class="pr-total-row">
          <span>Ara Toplam</span>
          <span><%= order.subtotal?.toLocaleString('tr-TR') %> TL</span>
        </div>
        <div class="pr-total-row">
          <span>Kargo</span>
          <span><%= order.shipping > 0 ? order.shipping.toLocaleString('tr-TR') + ' TL' : 'Ucretsiz' %></span>
        </div>
        <div class="pr-total-row grand">
          <span>Toplam</span>
          <span><%= order.total?.toLocaleString('tr-TR') %> TL</span>
        </div>
      </div>
    </div>

    <!-- Teslimat Bilgileri -->
    <div class="pr-card">
      <h3>Teslimat Bilgileri</h3>
      <div class="pr-info-row">
        <span class="label">Ad Soyad</span>
        <span class="value"><%= order.guest_name %></span>
      </div>
      <div class="pr-info-row">
        <span class="label">Telefon</span>
        <span class="value"><%= order.guest_phone %></span>
      </div>
      <% if (order.guest_email) { %>
      <div class="pr-info-row">
        <span class="label">E-posta</span>
        <span class="value"><%= order.guest_email %></span>
      </div>
      <% } %>
      <div class="pr-info-row">
        <span class="label">Adres</span>
        <span class="value"><%= order.address %></span>
      </div>
      <div class="pr-info-row">
        <span class="label">Il / Ilce</span>
        <span class="value"><%= order.city %><%= order.district ? ', ' + order.district : '' %></span>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
  function copyIban() {
    const iban = document.getElementById('ibanText').textContent.trim();
    navigator.clipboard.writeText(iban).then(() => {
      const btn = document.querySelector('.pr-copy-btn');
      btn.textContent = 'Kopyalandi!';
      setTimeout(() => { btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> IBAN Kopyala'; }, 2000);
    });
  }

  function confirmPayment() {
    const btn = document.getElementById('paymentBtn');
    btn.disabled = true;
    btn.textContent = 'Gonderiliyor...';

    fetch(window.location.pathname + '/onay', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    })
    .then(r => r.json())
    .then(data => {
      if (data.ok) {
        btn.className = 'pr-btn success';
        btn.textContent = 'Bildiriminiz Alindi - Odemeniz Kontrol Ediliyor';
        btn.disabled = true;
      } else {
        btn.disabled = false;
        btn.textContent = 'Odemeyi Yaptim';
      }
    })
    .catch(() => {
      btn.disabled = false;
      btn.textContent = 'Odemeyi Yaptim';
    });
  }
  </script>
</body>
</html>
